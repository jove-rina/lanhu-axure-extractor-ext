{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "author": "Jove Rina",
  "default_locale": "zh_CN",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "*://lanhuapp.com/*",
    "*://*.lanhuapp.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "提取 Axure 需求内容",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://lanhuapp.com/*",
        "*://*.lanhuapp.com/*"
      ],
      "js": ["content/marked.min.js", "content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/marked.min.js"],
      "matches": ["*://lanhuapp.com/*", "*://*.lanhuapp.com/*"]
    }
  ]
}
